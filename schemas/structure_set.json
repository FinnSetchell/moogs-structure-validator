{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["structures", "placement"],
  "properties": {
    "structures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["structure", "weight"],
        "properties": {
          "structure": { "type": "string" },
          "weight":    { "type": "integer" }
        }
      }
    },
    "placement": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" }
      }
    }
  }
}
